{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "oz-policy-builder",
	"main": "src/index.ts",
	"compatibility_date": "2025-03-10",
	"compatibility_flags": ["nodejs_compat"],

	"migrations": [
		{
			"new_sqlite_classes": ["MyMCP"],
			"tag": "v1"
		}
	],

	"durable_objects": {
		"bindings": [
			{
				"class_name": "MyMCP",
				"name": "MCP_OBJECT"
			}
		]
	},

	"observability": {
		"enabled": true
	},

	"dev": {
		"port": 8792
	}
}
