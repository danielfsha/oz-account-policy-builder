# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Rust ──────────────────────────────────────────────────────────────────────
target/
Cargo.lock
**/*.rs.bk

# ── Node / JS ─────────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Local env / secrets ───────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.dev.vars
*.pem
*.key
*.secret

# ── Testing / coverage ────────────────────────────────────────────────────────
coverage/

# ── Turbo ─────────────────────────────────────────────────────────────────────
.turbo/

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel/

# ── Build outputs ─────────────────────────────────────────────────────────────
.next/
out/
build/
dist/

# ── Wrangler / Cloudflare ─────────────────────────────────────────────────────
.wrangler/
wrangler-output/
*.wasm

# ── Soroban / Stellar ─────────────────────────────────────────────────────────
# Compiled WASM artefacts (tracked via stellar contract build, not git)
contracts/*/target/
generated/

# ── Debug logs ────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Temp / reference files ────────────────────────────────────────────────────
_tmp/
_commit.ps1
_build_output.txt
*.txt
!README.txt
